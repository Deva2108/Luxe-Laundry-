{
    "info": {
        "name": "LuxeLaundry API",
        "description": "API Collection for the Mini Laundry Order Management System",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Create Order",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Basic YWRtaW46YWRtaW4=" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"customerName\": \"John Doe\",\n    \"phoneNumber\": \"1234567890\",\n    \"isPriority\": false,\n    \"discountPercentage\": 10,\n    \"items\": [\n        {\n            \"garmentName\": \"Shirt\",\n            \"quantity\": 2,\n            \"pricePerItem\": 150.0,\n            \"category\": \"TOPWEAR\",\n            \"serviceType\": \"WASH_IRON\"\n        }\n    ]\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/api/orders",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8080",
                    "path": ["api", "orders"]
                }
            }
        },
        {
            "name": "2. Update Order Status",
            "request": {
                "method": "PUT",
                "header": [{ "key": "Authorization", "value": "Basic YWRtaW46YWRtaW4=" }],
                "url": {
                    "raw": "http://localhost:8080/api/orders/ORD-UNIQUE-ID/status?status=READY",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8080",
                    "path": ["api", "orders", "ORD-UNIQUE-ID", "status"],
                    "query": [{ "key": "status", "value": "READY" }]
                }
            }
        },
        {
            "name": "3. Delete Order",
            "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Basic YWRtaW46YWRtaW4=" }],
                "url": {
                    "raw": "http://localhost:8080/api/orders/ORD-UNIQUE-ID",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8080",
                    "path": ["api", "orders", "ORD-UNIQUE-ID"]
                }
            }
        },
        {
            "name": "4. Get Dashboard Stats",
            "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Basic YWRtaW46YWRtaW4=" }],
                "url": {
                    "raw": "http://localhost:8080/api/dashboard",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8080",
                    "path": ["api", "dashboard"]
                }
            }
        },
        {
            "name": "5. Get Pricing Library",
            "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Basic YWRtaW46YWRtaW4=" }],
                "url": {
                    "raw": "http://localhost:8080/api/garments/library",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8080",
                    "path": ["api", "garments", "library"]
                }
            }
        },
        {
            "name": "6. Save to Pricing Library",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Basic YWRtaW46YWRtaW4=" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"garmentName\": \"Silk Saree\",\n    \"defaultCategory\": \"ETHNIC\",\n    \"defaultPrice\": 450.0\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/api/garments/library",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8080",
                    "path": ["api", "garments", "library"]
                }
            }
        }
    ]
}